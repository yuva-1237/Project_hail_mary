# Project HAIL MARY – AI Provider Configuration
# Copy this file to .env and fill in your keys.
# The app works fully offline with the default Mock provider — no keys required.

# OpenAI (gpt-4o-mini)
# Get your key at: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=

# Anthropic (claude-3-5-haiku)
# Get your key at: https://console.anthropic.com/
# NOTE: Anthropic blocks browser CORS — you may need a server-side proxy.
VITE_ANTHROPIC_API_KEY=

# Google Gemini (gemini-1.5-flash)
# Get your key at: https://aistudio.google.com/app/apikey
# Supports browser CORS natively.
VITE_GEMINI_API_KEY=
